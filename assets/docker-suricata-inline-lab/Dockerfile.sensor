FROM debian:bookworm-slim

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        suricata \
        iptables \
        iproute2 \
        procps \
        curl \
        tcpdump \
        ethtool \
        jq \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/log/suricata /var/lib/suricata /var/run/suricata
